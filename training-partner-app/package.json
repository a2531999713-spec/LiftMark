{
  "name": "liftmark",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@expo/ui": "~56.0.16",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.4.0",
    "@shopify/flash-list": "^2.0.2",
    "date-fns": "^4.4.0",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.17",
    "expo-dev-client": "~56.0.19",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.10",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.9",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "nanoid": "^5.1.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.78.0",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.4",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:build": "expo run:android",
    "android:release": "expo run:android --variant release",
    "android:clean:native": "node scripts/clean-android-native.js",
    "android:apk": "cd android && gradlew.bat assembleRelease -PreactNativeArchitectures=x86_64",
    "android:apk:device": "cd android && gradlew.bat assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "android:apk:universal": "cd android && gradlew.bat assembleRelease -PreactNativeArchitectures=armeabi-v7a,arm64-v8a,x86,x86_64",
    "android:apk:clean": "npm run android:clean:native && npm run android:apk",
    "android:apk:install": "cd android && gradlew.bat installRelease -PreactNativeArchitectures=x86_64",
    "android:install": "adb install -r android\\app\\build\\outputs\\apk\\release\\app-release.apk",
    "android:open": "adb shell monkey -p com.liftmark.app -c android.intent.category.LAUNCHER 1",
    "android:preview": "npm run android:apk && npm run android:install && npm run android:open",
    "android:clear": "expo start --clear",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "private": true
}
